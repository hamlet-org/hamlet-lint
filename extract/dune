(executable
 (name main)
 (public_name hamlet-lint-extract)
 (package hamlet-lint)
 (libraries
  hamlet_lint_schema
  hamlet_lint_config
  compiler-libs.common
  yojson
  unix))

; compat.ml is generated from compat.cppo.ml by cppo, with the current
; OCaml version threaded in as -V OCAML:<version>. This is the only file
; in the project that gates on ocaml_version — the rest of extract/ is
; pure OCaml linking against compiler-libs.common.

(rule
 (targets compat.ml)
 (deps compat.cppo.ml)
 (action
  (run %{bin:cppo} -V OCAML:%{ocaml_version} %{deps} -o %{targets})))
